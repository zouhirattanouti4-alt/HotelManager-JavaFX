<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ma.ensao.hotel.controller.MainController"
            fx:id="rootPane" styleClass="app-root"
            prefWidth="1300.0" prefHeight="800.0">

    <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Fichier">
                        <items>
                            <MenuItem text="Actualiser les donnees" onAction="#handleActualiser"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Quitter" onAction="#handleQuitter"/>
                        </items>
                    </Menu>
                    <Menu text="Affichage">
                        <items>
                            <MenuItem text="Chambres" onAction="#handleAfficherChambres"/>
                            <MenuItem text="Reservations" onAction="#handleAfficherReservations"/>
                            <MenuItem text="Tableau de bord" onAction="#handleAfficherDashboard"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="Basculer le theme clair / sombre" onAction="#handleToggleThemeMenu"/>
                        </items>
                    </Menu>
                    <Menu text="Aide">
                        <items>
                            <MenuItem text="Guide d'utilisation" onAction="#handleGuide"/>
                            <MenuItem text="A propos" onAction="#handleApropos"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="14.0">
                <Label text="🏨" styleClass="app-logo"/>
                <VBox spacing="0.0">
                    <Label text="HotelManager" styleClass="app-title"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER_RIGHT" spacing="0.0">
                    <Label fx:id="lblGreeting" text="Bonjour" styleClass="header-greeting"/>
                    <Label fx:id="lblDate" text="" styleClass="app-subtitle"/>
                </VBox>
                <Label fx:id="lblClock" text="00:00:00" styleClass="header-clock"/>
                <ToggleButton fx:id="btnTheme" text="🌙" styleClass="theme-toggle"
                              onAction="#handleToggleTheme">
                    <tooltip><Tooltip text="Basculer entre le theme clair et sombre"/></tooltip>
                </ToggleButton>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="6.0">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="✦" styleClass="app-logo"/>
                <VBox spacing="0.0">
                    <Label text="Maison Azur" styleClass="sidebar-brand"/>
                    <Label text="ENSAO • GI3" styleClass="sidebar-brand-sub"/>
                </VBox>
            </HBox>

            <Label text="NAVIGATION" styleClass="sidebar-section"/>

            <Button fx:id="navChambres" text="  Chambres" styleClass="nav-btn"
                    onAction="#handleNavChambres" maxWidth="Infinity">
                <graphic>
                    <SVGPath content="M3 7v10h18V7H3zm16 8H5V9h14v6z" fill="white" scaleX="1.2" scaleY="1.2"/>
                </graphic>
            </Button>
            <Button fx:id="navReservations" text="  Reservations" styleClass="nav-btn"
                    onAction="#handleNavReservations" maxWidth="Infinity">
                <graphic>
                    <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z" fill="white" scaleX="1.1" scaleY="1.1"/>
                </graphic>
            </Button>
            <Button fx:id="navDashboard" text="  Tableau de bord" styleClass="nav-btn"
                    onAction="#handleNavDashboard" maxWidth="Infinity">
                <graphic>
                    <SVGPath content="M3 3v18h18V21H5V3H3zm6 14h2V11H9v6zm4 0h2V7h-2v10zm4 0h2v-4h-2v4z" fill="white" scaleX="1.2" scaleY="1.2"/>
                </graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="sidebar-badge" spacing="4.0">
                <Label text="💡 Astuce" style="-fx-font-weight:bold;"/>
                <Label text="Changez la couleur d'accent depuis le tableau de bord : tout l'habillage s'adapte."
                       wrapText="true" style="-fx-font-size:11px;"/>
            </VBox>

            <Label text="© 2025-2026 • Java IHM" styleClass="sidebar-footer">
                <padding><Insets top="8"/></padding>
            </Label>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="content-area">
            <fx:include fx:id="chambres" source="ChambreView.fxml"/>
            <fx:include fx:id="reservations" source="ReservationView.fxml"/>
            <fx:include fx:id="dashboard" source="DashboardView.fxml"/>
        </StackPane>
    </center>
</BorderPane>